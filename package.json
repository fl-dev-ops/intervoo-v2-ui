{
  "name": "diagnostic",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vp dev --port 3000",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test run",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "prepare": "vp config",
    "postinstall": "prisma generate && prisma migrate deploy"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.15",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.4.2",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "@trpc/tanstack-react-query": "^11.11.0",
    "better-auth": "^1.5.3",
    "livekit-client": "2.15.11",
    "livekit-server-sdk": "^2.14.2",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "prisma": "^7.4.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "superjson": "^2.2.2",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "better-sqlite3"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
