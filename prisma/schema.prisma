generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PreDiagnosticSessionStatus {
  STARTED
  COMPLETED
  REPORT_READY
}

enum PreDiagnosticSessionReportStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model User {
  id                     String                    @id
  name                   String
  email                  String
  emailVerified          Boolean                   @default(false)
  image                  String?
  phoneNumber            String?                   @unique
  phoneNumberVerified    Boolean                   @default(false)
  hasCompletedOnboarding Boolean                   @default(false)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  sessions               Session[]
  accounts               Account[]
  profile                Profile?
  preDiagnosticSessions  PreDiagnosticSession[]

  @@unique([email])
  @@map("user")
}

model Profile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredName        String   @default("")
  institution          String
  degree               String
  stream               String
  yearOfStudy          String
  placementPreparation String   @default("")
  academySelection     String   @default("")
  academyName          String   @default("")
  nativeLanguage       String   @default("")
  englishLevel         String   @default("")
  speakingSpeed        String   @default("")
  coach                String   @default("")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@map("profile")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model PreDiagnosticSession {
  id              String                       @id @default(cuid())
  userId          String
  user            User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          PreDiagnosticSessionStatus   @default(STARTED)
  roomName        String                       @unique
  egressId        String?
  videoUrl        String?
  startedAt       DateTime                     @default(now())
  endedAt         DateTime?
  transcript      Json?
  sessionMetadata Json?
  report          PreDiagnosticSessionReport?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@index([egressId])
  @@map("pre_diagnostic_session")
}

model PreDiagnosticSessionReport {
  id            String                              @id @default(cuid())
  sessionId     String                              @unique
  session       PreDiagnosticSession                @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status        PreDiagnosticSessionReportStatus    @default(PENDING)
  promptVersion String?
  fileUri       String?
  reportJson    Json?
  errorMessage  String?
  metadata      Json?
  createdAt     DateTime                            @default(now())
  updatedAt     DateTime                            @updatedAt

  @@index([status])
  @@map("pre_diagnostic_session_report")
}
