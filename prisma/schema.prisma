generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PreScreenSessionStatus {
  STARTED
  COMPLETED
  REPORT_READY
}

enum PreScreenSessionReportStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum DiagnosticSessionStatus {
  STARTED
  COMPLETED
  REPORT_READY
}

enum DiagnosticSessionReportStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model User {
  id                     String         @id
  name                   String
  email                  String
  emailVerified          Boolean        @default(false)
  image                  String?
  phoneNumber            String?        @unique
  phoneNumberVerified    Boolean        @default(false)
  hasCompletedOnboarding Boolean        @default(false)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  sessions               Session[]
  accounts               Account[]
  profile                Profile?
  diagnosticSessions     DiagnosticSession[]

  @@unique([email])
  @@map("user")
}

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredName       String   @default("")
  institution         String
  degree              String
  stream              String
  yearOfStudy         String
  placementPreparation String   @default("")
  academySelection    String   @default("")
  academyName         String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@map("profile")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model PreScreenQuestionnaireDraft {
  id                 String                 @id @default(cuid())
  status             PreScreenSessionStatus @default(STARTED)
  currentStep        String                 @default("intro")
  schemaVersion      Int                    @default(1)
  questionSetKey     String                 @default("pre-screen-v1")
  answers            Json
  latestAgentContext Json?
  completedAt        DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  session            PreScreenSession?

  @@index([status])
  @@index([updatedAt])
  @@index([questionSetKey, schemaVersion])
}

model PreScreenSession {
  id                String                      @id @default(cuid())
  draftId           String                      @unique
  draft             PreScreenQuestionnaireDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  status            PreScreenSessionStatus      @default(STARTED)
  roomName          String?                     @unique
  egressId          String?
  audioUrl          String?
  startedAt         DateTime                    @default(now())
  endedAt           DateTime?
  transcript        Json?
  sessionMetadata   Json?
  report            PreScreenSessionReport?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([status])
  @@index([startedAt])
  @@index([egressId])
}

model PreScreenSessionReport {
  id          String                       @id @default(cuid())
  sessionId   String                       @unique
  session     PreScreenSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status      PreScreenSessionReportStatus @default(PENDING)
  promptVersion String?
  fileUri     String?
  reportJson  Json?
  errorMessage String?
  metadata    Json?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  @@index([status])
}

model DiagnosticSession {
  id                String                  @id @default(cuid())
  userId            String
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            DiagnosticSessionStatus @default(STARTED)
  roomName          String                  @unique
  egressId          String?
  videoUrl          String?
  startedAt         DateTime                @default(now())
  endedAt           DateTime?
  transcript        Json?
  sessionMetadata   Json?
  report            DiagnosticSessionReport?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@index([egressId])
}

model DiagnosticSessionReport {
  id            String                         @id @default(cuid())
  sessionId     String                         @unique
  session       DiagnosticSession              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status        DiagnosticSessionReportStatus  @default(PENDING)
  promptVersion String?
  fileUri       String?
  reportJson    Json?
  errorMessage  String?
  metadata      Json?
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt

  @@index([status])
}
