{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import", "react", "vitest"],
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "options": {
    "typeAware": true
  },
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    ".output/**",
    ".tanstack/**",
    "coverage/**",
    "**/routeTree.gen.ts"
  ],
  "rules": {
    "react-in-jsx-scope": "off",
    "prefer-array-find": "off",
    "no-array-index-key": "off",
    "no-named-as-default-member": "off",
    "no-shadow": "off",
    "prefer-set-has": "off",
    "no-unsafe-type-assertion": "off",
    "no-redundant-type-constituents": "off",
    "no-await-in-loop": "off"
  }
}
